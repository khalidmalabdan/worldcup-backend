generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  predictions     Prediction[]
  leagueMembers   LeagueMember[]
  weeklyTrophies  WeeklyTrophy[]
}

model Match {
  id         String @id @default(uuid())
  externalId Int    @unique

  homeTeam String
  awayTeam String

  homeScore Int?
  awayScore Int?

  kickoffTime DateTime
  matchDate   String

  status String
  scored Boolean @default(false)

  homeLogo String?
  awayLogo String?
  homeFlag String?
  awayFlag String?

  events      String @default("")
  homePlayers String @default("")
  awayPlayers String @default("")

  predictions Prediction[]
}

model Prediction {
  id      String @id @default(uuid())
  userId  String
  matchId String

  homeScore Int
  awayScore Int

  scorers     String
  assisters   String
  goalMinutes String @default("")

  doublePoint Boolean @default(false)
  points      Int     @default(0)

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])
}

model League {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  logo      String?
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        LeagueMember[]
  weeklyTrophies WeeklyTrophy[]
}

model LeagueMember {
  id       String   @id @default(uuid())
  userId   String
  leagueId String
  role     String   @default("MEMBER")
  points   Int      @default(0)
  joinedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  league League @relation(fields: [leagueId], references: [id])

  @@unique([userId, leagueId])
}

model WeeklyTrophy {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String
  weekStart DateTime
  weekEnd   DateTime
  trophy    String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  league League @relation(fields: [leagueId], references: [id])
}
